import { stat } from "node:fs"
import { db } from "./Backend/src/models/post.model"

db.studentsAgg.aggregate([
    {
        $addFields:{
            totalMarks: {$sum: "$marks"},
            numOfSub: {$size: "$marks"}
        }
    },
    {
        $addFields:{
            percentage: {$divide: ['$totalMarks', '$numOfSub' ]    }
        }
    },
    {
     $addFields:{
        grade:{
            $cond:{
                if:{
                  $gte:["$percentage", 33]
                },
                then: "Pass",
                else: "Fail"


                 }
              }
           }
    },
    {
        $project: {
            marks: 0,
            numOfSub: 0
        }
    }
])



db.studentsAgg.aggregate([
    {
        $addFields:{
            totalMarks: {$sum: "$marks"},
            numOfSub: {$size: "$marks"}
        }
    },
    {
        $addFields:{
            percentage: {$divide: ['$totalMarks', '$numOfSub' ]    }
        }
    },
    {
     $addFields:{
        grade:{
$switch:{
    branches:[
        {
            case: {$gte:["$percentage", 90]},
            then: "A+"
        },
        {
            case: {$gte:["$percentage", 80]},
            then: "A"
        },
        {
            case: {$gte:["$percentage", 70]},
            then: "B+"
        },
        {
            case: {$gte:["$percentage", 60]},
            then: "B"
        },
        {
            case: {$gte:["$percentage", 50]},
            then: "C+"
        },
        {
            case: {$gte:["$percentage", 40]},
            then: "C"
        }
    ],
    default:"Fail"
}
              }
           }
    },
    {
        $project: {
            marks: 0,
            numOfSub: 0
        }
    }
])


